# Получить можно здесь: https://my.telegram.org/auth/login
TELEGRAM_API_ID=123456789
TELEGRAM_API_HASH=your_api_hash_here

# ID группового чата для мониторинга
# Пример: -1002584565460
TELEGRAM_CHAT_ID=-1002584565460

# Ваш номер телефона (формат: +7XXXXXXXXXX или +1XXXXXXXXXX)
TELEGRAM_PHONE=+7XXXXXXXXXX

# ID пользователей, на чьи сообщения реагировать (через запятую)
# Пример: 123456789,987654321,555555555
ALLOWED_USER_IDS=123456789