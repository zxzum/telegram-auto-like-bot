# Telegram API credentials from https://my.telegram.org
TELEGRAM_API_ID=18756410
TELEGRAM_API_HASH=your_api_hash_here_32_characters

# Your Telegram phone number
TELEGRAM_PHONE=+7XXXXXXXXXX

# Target group chat ID (negative number for groups)
TELEGRAM_CHAT_ID=-1002584565460

# Target topic/thread ID in the group
# Get it from the URL: https://t.me/c/2584565460/2683
# In this example, topic ID is 2683
TELEGRAM_TOPIC_ID=2683

# Comma-separated list of user IDs to react to
ALLOWED_USER_IDS=1046295225

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Rate limiting delay in seconds (minimum 1.0 to avoid flood)
RATE_LIMIT_DELAY=2.0

# Maximum number of retries
MAX_RETRIES=3

# Retry delay in seconds
RETRY_DELAY=5.0

# Request timeout in seconds
REQUEST_TIMEOUT=30

# Idle timeout in seconds (detect if bot is stuck)
IDLE_TIMEOUT=300